{
  "scopeName": "pyjinhx.injection.def-header",
  "injectionSelector": "L:text.html.jinja, L:text.html.basic, L:text.pyjinhx",
  "patterns": [
    {
      "name": "meta.pyjinhx-def-header",
      "begin": "(\\{#-?)(def)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.import.python"
        },
        "2": {
          "name": "keyword.control.import.python"
        }
      },
      "end": "(-?#\\})",
      "endCaptures": {
        "1": {
          "name": "keyword.control.import.python"
        }
      },
      "patterns": [
        {
          "include": "#pyjinhx-def-signature"
        }
      ]
    }
  ],
  "repository": {
    "pyjinhx-def-signature": {
      "patterns": [
        {
          "match": "((?:\"(?:[^\"\\\\]|\\\\.)*\")|(?:'(?:[^'\\\\]|\\\\.)*'))",
          "name": "string.quoted.python"
        },
        {
          "match": "\\b(True|False|None)\\b",
          "captures": {
            "1": {
              "name": "constant.language.python"
            }
          }
        },
        {
          "match": "\\b(int|str|float|bool|bytes|list|dict|set|tuple|Any|Optional|Union|Literal|Sequence|Mapping|Callable|TypeVar|Protocol)\\b",
          "captures": {
            "1": {
              "name": "support.type.python"
            }
          }
        },
        {
          "match": "\\b([a-z_][\\w]*)\\b(?=\\s*:)",
          "captures": {
            "1": {
              "name": "variable.parameter.python"
            }
          }
        },
        {
          "match": "[:=,]",
          "name": "punctuation.separator.pyjinhx-def"
        }
      ]
    }
  }
}
