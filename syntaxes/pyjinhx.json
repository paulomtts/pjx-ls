{
  "name": "PyJinHx",
  "scopeName": "text.pyjinhx",
  "patterns": [
    {
      "include": "#pyjinhx-interpolation"
    },
    {
      "include": "#pyjinhx-python-block"
    },
    {
      "include": "#pyjinhx-def-header"
    },
    {
      "include": "#pyjinhx-component-tag"
    },
    {
      "include": "text.html.jinja"
    },
    {
      "include": "text.html.basic"
    }
  ],
  "repository": {
    "pyjinhx-component-tag": {
      "patterns": [
        {
          "begin": "(</?)([A-Z][A-Za-z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.pyjinhx" },
            "2": { "name": "entity.name.tag.pyjinhx" }
          },
          "end": "(/?>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.pyjinhx" }
          },
          "patterns": [
            { "include": "#pyjinhx-interpolation" },
            {
              "begin": "\"(?=\\s*$)",
              "beginCaptures": {
                "0": { "name": "string.quoted.double.html punctuation.definition.string.begin.html" }
              },
              "end": "\"",
              "endCaptures": {
                "0": { "name": "string.quoted.double.html punctuation.definition.string.end.html" }
              },
              "patterns": [{ "include": "$self" }]
            },
            {
              "begin": "\"(?=\\s*</?[A-Za-z])",
              "beginCaptures": {
                "0": { "name": "string.quoted.double.html punctuation.definition.string.begin.html" }
              },
              "end": "\"",
              "endCaptures": {
                "0": { "name": "string.quoted.double.html punctuation.definition.string.end.html" }
              },
              "patterns": [{ "include": "$self" }]
            },
            {
              "begin": "\"",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.html" }
              },
              "end": "\"",
              "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.html" }
              },
              "name": "string.quoted.double.html",
              "patterns": [{ "include": "#pyjinhx-interpolation" }]
            },
            {
              "match": "'[^']*'",
              "name": "string.quoted.single.html"
            },
            {
              "match": "([a-zA-Z_][\\w:-]*)(?=\\s*=)",
              "name": "entity.other.attribute-name.html"
            }
          ]
        }
      ]
    },
    "pyjinhx-interpolation": {
      "patterns": [
        {
          "name": "meta.pyjinhx-interpolation",
          "begin": "(\\{\\{-?)",
          "beginCaptures": {
            "1": {
              "name": "constant.character.format.placeholder.other.python"
            }
          },
          "end": "(-?\\}\\})",
          "endCaptures": {
            "1": {
              "name": "constant.character.format.placeholder.other.python"
            }
          },
          "contentName": "constant.character.format.placeholder.other.python",
          "applyEndPatternLast": true,
          "patterns": []
        }
      ]
    },
    "pyjinhx-python-block": {
      "patterns": [
        {
          "name": "meta.pyjinhx-python-block",
          "begin": "(\\{#-?)\\s*(python)\\s*$",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.pyjinhx" },
            "2": { "name": "keyword.control.import.pyjinhx" }
          },
          "end": "^\\s*(-?#\\})\\s*$",
          "endCaptures": {
            "1": { "name": "keyword.control.import.pyjinhx" }
          },
          "contentName": "source.python",
          "patterns": [{ "include": "source.python" }]
        }
      ]
    },
    "pyjinhx-def-header": {
      "patterns": [
        {
          "name": "meta.pyjinhx-def-header",
          "begin": "(\\{#-?)(def)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.pyjinhx"
            },
            "2": {
              "name": "keyword.control.import.pyjinhx"
            }
          },
          "end": "(-?#\\})",
          "endCaptures": {
            "1": {
              "name": "keyword.control.import.pyjinhx"
            }
          },
          "patterns": [
            {
              "include": "#pyjinhx-def-signature"
            }
          ]
        }
      ]
    },
    "pyjinhx-def-signature": {
      "patterns": [
        {
          "match": "((?:\"(?:[^\"\\\\]|\\\\.)*\")|(?:'(?:[^'\\\\]|\\\\.)*'))",
          "name": "string.quoted.python"
        },
        {
          "match": "\\b(True|False|None)\\b",
          "captures": {
            "1": {
              "name": "constant.language.python"
            }
          }
        },
        {
          "match": "\\b(int|str|float|bool|bytes|list|dict|set|tuple|Any|Optional|Union|Literal|Sequence|Mapping|Callable|TypeVar|Protocol)\\b",
          "captures": {
            "1": {
              "name": "support.type.python"
            }
          }
        },
        {
          "match": "\\b([a-z_][\\w]*)\\b(?=\\s*:)",
          "captures": {
            "1": {
              "name": "variable.parameter.python"
            }
          }
        },
        {
          "match": "[:=,]",
          "name": "punctuation.separator.pyjinhx-def"
        },
        {
          "match": "[\\[\\]{}()]",
          "name": "punctuation.bracket.pyjinhx"
        }
      ]
    }
  }
}
