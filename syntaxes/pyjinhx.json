{
  "name": "PyJinHx",
  "scopeName": "text.pyjinhx",
  "patterns": [
    {
      "include": "#pyjinhx-interpolation"
    },
    {
      "include": "#pyjinhx-def-header"
    },
    {
      "include": "text.html.jinja"
    },
    {
      "include": "text.html.basic"
    }
  ],
  "repository": {
    "pyjinhx-interpolation": {
      "patterns": [
        {
          "name": "meta.pyjinhx-interpolation",
          "begin": "(\\{\\{-?)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.interpolation.begin.pyjinhx"
            }
          },
          "end": "(-?\\}\\})",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.interpolation.end.pyjinhx"
            }
          },
          "contentName": "variable.other.pyjinhx-interpolation",
          "applyEndPatternLast": true,
          "patterns": []
        }
      ]
    },
    "pyjinhx-def-header": {
      "patterns": [
        {
          "name": "meta.pyjinhx-def-header",
          "begin": "(\\{#-?)(def)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.pyjinhx"
            },
            "2": {
              "name": "keyword.control.import.pyjinhx"
            }
          },
          "end": "(-?#\\})",
          "endCaptures": {
            "1": {
              "name": "keyword.control.import.pyjinhx"
            }
          },
          "patterns": [
            {
              "include": "#pyjinhx-def-signature"
            }
          ]
        }
      ]
    },
    "pyjinhx-def-signature": {
      "patterns": [
        {
          "match": "((?:\"(?:[^\"\\\\]|\\\\.)*\")|(?:'(?:[^'\\\\]|\\\\.)*'))",
          "name": "string.quoted.python"
        },
        {
          "match": "\\b(True|False|None)\\b",
          "captures": {
            "1": {
              "name": "constant.language.python"
            }
          }
        },
        {
          "match": "\\b(int|str|float|bool|bytes|list|dict|set|tuple|Any|Optional|Union|Literal|Sequence|Mapping|Callable|TypeVar|Protocol)\\b",
          "captures": {
            "1": {
              "name": "support.type.python"
            }
          }
        },
        {
          "match": "\\b([a-z_][\\w]*)\\b(?=\\s*:)",
          "captures": {
            "1": {
              "name": "variable.parameter.python"
            }
          }
        },
        {
          "match": "[:=,]",
          "name": "punctuation.separator.pyjinhx-def"
        }
      ]
    }
  }
}
