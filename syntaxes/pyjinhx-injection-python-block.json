{
  "scopeName": "pyjinhx.injection.python-block",
  "injectionSelector": "L:text.html.jinja, L:text.html.basic, L:text.pyjinhx",
  "patterns": [
    {
      "name": "meta.pyjinhx-python-block",
      "begin": "(\\{#-?)\\s*(python)\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.import.pyjinhx" },
        "2": { "name": "keyword.control.import.pyjinhx" }
      },
      "end": "^\\s*(-?#\\})\\s*$",
      "endCaptures": {
        "1": { "name": "keyword.control.import.pyjinhx" }
      },
      "contentName": "source.python",
      "patterns": [{ "include": "source.python" }]
    }
  ]
}
