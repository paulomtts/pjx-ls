{
  "scopeName": "pyjinhx.injection.interpolation-in-jinja",
  "injectionSelector": "L:meta.expression.jinja -meta.pyjinhx-interpolation",
  "patterns": [
    {
      "match": "\\G\\s*",
      "name": "meta.embedded.pyjinhx"
    },
    {
      "match": ".+",
      "name": "meta.embedded.pyjinhx"
    }
  ]
}
