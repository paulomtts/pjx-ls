{#def view: str = "chat" #}
<div class="sidebar">
  <div class="sidebar__top">
    <PJXButton
      variant="secondary"
      start="
        <PJXIcon name='plus'/>
      "
      center="{{ t.new }}"
    />
  </div>
  {% for group in groups %}
    <PJXAccordion label="{{ group.label }}">
      {% for item in group.items %}
        <ConversationItem conversation="{{ item.id }}" title="{{ item.title }}"/>
      {% endfor %}
    </PJXAccordion>
  {% endfor %}
</div>
